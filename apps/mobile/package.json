{
  "name": "@smartstat/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "start:tenant": "cross-env-shell expo start",
    "start:demo": "cross-env SMARTSTAT_TENANT_SLUG=demo-hospital expo start",
    "start:memorial": "cross-env SMARTSTAT_TENANT_SLUG=memorial-hospital expo start",
    "build:directory:preview": "eas build --profile directory-preview",
    "build:demo:preview": "eas build --profile demo-hospital-preview",
    "build:memorial:preview": "eas build --profile memorial-hospital-preview",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.3",
    "@smartstat/shared": "workspace:*",
    "@supabase/supabase-js": "^2.46.1",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-sensors": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "~19.1.0",
    "cross-env": "^7.0.3",
    "typescript": "~5.9.2"
  }
}
