{
  "name": "smartstat-ai",
  "version": "0.1.0",
  "private": true,
  "description": "SmartStat AI — white-label indoor navigation for hospitals",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:admin": "pnpm --filter @smartstat/admin dev",
    "dev:mobile": "pnpm --filter @smartstat/mobile start",
    "build:admin": "pnpm --filter @smartstat/admin build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf node_modules .next .expo dist"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@11.1.3"
}
